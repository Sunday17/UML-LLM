@startuml
title 时序图：检索图书
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}


    
        ' 第一个参与者使用特殊标记
        
actor "用户" << (A,#FFAAAA) >> order 0
        
    

    
        
boundary "图书检索前端页面"
        
    

    
        
control "图书检索服务"
        
    

    
        
database "图书数据库"
        
    




    
        
"用户" -> "图书检索前端页面" : 输入图书检索条件（如书名、关键词或作者）并触发检索
        
    
        
"图书检索前端页面" -> "图书检索服务" : 发送图书检索请求
        
    
        
"图书检索服务" -> "图书数据库" : 执行图书信息查询
        
    
        
"图书数据库" --> "图书检索服务" : 返回图书查询结果集
        
    
        
"图书检索服务" --> "图书检索前端页面" : 返回检索处理结果
        
    
        
"图书检索前端页面" --> "用户" : 展示检索结果界面
        
    

@enduml