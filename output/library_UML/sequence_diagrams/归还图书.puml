@startuml
title 时序图：归还图书
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}


    
        ' 第一个参与者使用特殊标记
        
actor "用户" << (A,#FFAAAA) >> order 0
        
    

    
        
boundary "图书归还界面"
        
    

    
        
control "借阅管理服务"
        
    

    
        
database "图书数据库"
        
    

    
        
control "逾期处理模块"
        
    

    
        
participant "通知系统"
        
    




    
        
"用户" -> "图书归还界面" : 提交图书归还请求（扫描图书）
        
    
        
"图书归还界面" -> "借阅管理服务" : 发送归还图书请求
        
    
        
"借阅管理服务" -> "图书数据库" : 查询图书借阅记录及应还日期
        
    
        
"图书数据库" --> "借阅管理服务" : 返回借阅记录数据
        
    
        
"借阅管理服务" -> "逾期处理模块" : 请求计算逾期并处理
        
    
        
"逾期处理模块" -> "图书数据库" : 生成逾期费用记录
        
    
        
"图书数据库" --> "逾期处理模块" : 返回记录生成结果
        
    
        
"逾期处理模块" --> "借阅管理服务" : 返回逾期处理结果
        
    
        
"借阅管理服务" -> "图书数据库" : 更新图书状态为已归还
        
    
        
"图书数据库" --> "借阅管理服务" : 返回状态更新确认
        
    
        
"借阅管理服务" -> "通知系统" : 发送逾期通知请求
        
    
        
"通知系统" --> "借阅管理服务" : 返回通知发送确认
        
    
        
"借阅管理服务" --> "图书归还界面" : 返回归还处理完成结果
        
    
        
"图书归还界面" --> "用户" : 展示归还结果及逾期信息
        
    

@enduml