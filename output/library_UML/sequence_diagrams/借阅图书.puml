@startuml
title 时序图：借阅图书
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}


    
        ' 第一个参与者使用特殊标记
        
actor "师生" << (A,#FFAAAA) >> order 0
        
    

    
        
boundary "图书借阅界面"
        
    

    
        
control "借阅管理服务"
        
    

    
        
control "用户身份验证服务"
        
    

    
        
control "图书状态管理服务"
        
    

    
        
control "借阅记录服务"
        
    

    
        
database "用户数据库"
        
    

    
        
database "图书数据库"
        
    

    
        
database "借阅记录数据库"
        
    




    
        
"师生" -> "图书借阅界面" : 输入图书编号并提交借阅请求
        
    
        
"图书借阅界面" -> "借阅管理服务" : 发送借阅请求，包含用户ID和图书ID
        
    
        
"借阅管理服务" -> "用户身份验证服务" : 请求验证用户身份
        
    
        
"用户身份验证服务" -> "用户数据库" : 查询用户信息及借阅权限
        
    
        
"用户数据库" --> "用户身份验证服务" : 返回用户验证结果
        
    
        
"用户身份验证服务" --> "借阅管理服务" : 返回用户身份验证结果
        
    
        
"借阅管理服务" -> "图书状态管理服务" : 请求验证图书可借状态
        
    
        
"图书状态管理服务" -> "图书数据库" : 查询图书库存及借阅状态
        
    
        
"图书数据库" --> "图书状态管理服务" : 返回图书状态信息
        
    
        
"图书状态管理服务" --> "借阅管理服务" : 返回图书状态验证结果
        
    
        
"借阅管理服务" -> "借阅记录服务" : 请求创建借阅记录
        
    
        
"借阅记录服务" -> "借阅记录数据库" : 插入新的借阅记录
        
    
        
"借阅记录数据库" --> "借阅记录服务" : 返回借阅记录创建成功
        
    
        
"借阅记录服务" --> "借阅管理服务" : 返回借阅记录创建成功
        
    
        
"借阅管理服务" -> "图书状态管理服务" : 请求更新图书状态为已借出
        
    
        
"图书状态管理服务" -> "图书数据库" : 更新图书借阅状态
        
    
        
"图书数据库" --> "图书状态管理服务" : 返回图书状态更新成功
        
    
        
"图书状态管理服务" --> "借阅管理服务" : 返回图书状态更新成功
        
    
        
"借阅管理服务" --> "图书借阅界面" : 返回借阅成功结果
        
    
        
"图书借阅界面" --> "师生" : 显示借阅成功信息
        
    

@enduml