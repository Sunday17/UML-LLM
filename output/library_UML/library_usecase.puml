actor "管理员"


usecase "管理图书"

usecase "借阅图书"

usecase "检索图书"

usecase "归还图书"

usecase "查询借阅记录"



"学生" -- "检索图书"

"学生" -- "借阅图书"

"学生" -- "归还图书"

"学生" -- "查询借阅记录"



"老师" -- "检索图书"

"老师" -- "借阅图书"

"老师" -- "归还图书"

"老师" -- "查询借阅记录"



"管理员" -- "查询借阅记录"

"管理员" -- "管理图书"




"借阅图书" ..> "检索图书" : <<include>>




