@startuml
title 自动生成：系统类图
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50

class "User" {
  ' 属性区 (默认设为 private: -)
  - user_id;
  - name;
  - card_number;
  - borrow_permission;
  ' 方法区 (默认设为 public: +)
  + searchBook();
  + borrowBook();
  + returnBook();
  + viewBorrowRecords();
}

class "Student" {
  ' 属性区 (默认设为 private: -)
  - student_id;
  - card_number;
  - borrow_permission;
  ' 方法区 (默认设为 public: +)
  + searchBook();
  + borrowBook();
  + returnBook();
  + viewBorrowRecords();
}

class "Teacher" {
  ' 属性区 (默认设为 private: -)
  - teacher_id;
  - card_number;
  - borrow_permission;
  ' 方法区 (默认设为 public: +)
  + searchBook();
  + borrowBook();
  + returnBook();
  + viewBorrowRecords();
}

class "Administrator" {
  ' 属性区 (默认设为 private: -)
  - admin_id;
  - permissions;
  ' 方法区 (默认设为 public: +)
  + addBook();
  + updateBookInfo();
  + removeBook();
  + viewBorrowRecords();
}

class "Book" {
  ' 属性区 (默认设为 private: -)
  - book_id;
  - title;
  - author;
  - isbn;
  - status;
  - location;
  ' 方法区 (默认设为 public: +)
  + getStatus();
  + setStatus();
  + isAvailable();
}

class "BorrowRecord" {
  ' 属性区 (默认设为 private: -)
  - record_id;
  - user_id;
  - book_id;
  - borrow_date;
  - due_date;
  - status;
  ' 方法区 (默认设为 public: +)
  + createBorrowRecord();
  + validateBorrow();
}

class "ReturnRecord" {
  ' 属性区 (默认设为 private: -)
  - return_id;
  - borrow_record_id;
  - return_date;
  - overdue_fee;
  ' 方法区 (默认设为 public: +)
  + createReturnRecord();
  + calculateOverdue();
}

class "OverdueRecord" {
  ' 属性区 (默认设为 private: -)
  - overdue_id;
  - borrow_record_id;
  - overdue_days;
  - fee;
  ' 方法区 (默认设为 public: +)
  + generateOverdueRecord();
}

' 2.1 Association (关联关系: --)

"User" o-- "BorrowRecord"

"User" o-- "ReturnRecord"

"User" o-- "OverdueRecord"

"Book" o-- "BorrowRecord"

"Book" o-- "ReturnRecord"

"Book" o-- "OverdueRecord"


"Student" --|> "User"

"Teacher" --|> "User"

"Administrator" --|> "User"




@enduml