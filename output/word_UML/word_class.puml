@startuml
title 自动生成：系统类图
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50
class "Achievement" {
  ' 属性区 (默认设为 private: -)
  - 徽章名称;
  - 徽章描述;
  - 解锁条件;
  - 解锁时间;
  - 稀有度;
  - 奖励内容;
  - 徽章分类;
  - 图标;
  ' 方法区 (默认设为 public: +)
  + 解锁();
  + 展示();
}
class "CheckIn" {
  ' 属性区 (默认设为 private: -)
  - 打卡日期;
  - 连续打卡天数;
  - 累计打卡天数;
  - 打卡状态;
  - 用户ID;
  - 奖励成长值;
  - 奖励徽章碎片;
  - 打卡海报;
  ' 方法区 (默认设为 public: +)
  + 打卡();
  + 生成打卡海报();
  + 分享();
}
class "CommunityPost" {
  ' 属性区 (默认设为 private: -)
  - 发布内容;
  - 发布时间;
  - 发布者ID;
  - 话题标签;
  - 配图列表;
  - 点赞数;
  - 评论数;
  - 收藏数;
  - 转发数;
  - 审核状态;
  ' 方法区 (默认设为 public: +)
  + 发布();
  + 点赞();
  + 评论();
  + 收藏();
  + 转发();
  + 审核();
}
class "CustomVocabularyBook" {
  ' 属性区 (默认设为 private: -)
  - 词书名称;
  - 封面;
  - 创建者ID;
  - 创建时间;
  - 单词列表;
  - 单词释义;
  - 单词例句;
  - 个人备注;
  - 单词数量上限;
  - 创建方式;
  ' 方法区 (默认设为 public: +)
  + 创建();
  + 编辑();
  + 导入单词();
  + 设置为学习词书();
}
class "LearningPlan" {
  ' 属性区 (默认设为 private: -)
  - 目标词书;
  - 考试时间;
  - 每日新学单词量;
  - 每日复习单词量;
  - 生成日期;
  - 计划状态;
  - 用户ID;
  - 补卡次数;
  ' 方法区 (默认设为 public: +)
  + 生成计划();
  + 调整计划();
  + 重新计算计划();
}
class "LearningSession" {
  ' 属性区 (默认设为 private: -)
  - 学习时间;
  - 学习单词列表;
  - 学习模式;
  - 学习进度;
  - 用户ID;
  - 本次学习数据;
  - 掌握度选择记录;
  ' 方法区 (默认设为 public: +)
  + 开始学习();
  + 结束学习();
  + 切换模式();
  + 记录学习数据();
}
class "MistakeBook" {
  ' 属性区 (默认设为 private: -)
  - 错题列表;
  - 错误次数;
  - 错误类型;
  - 错误时间;
  - 用户ID;
  - 高频错题标记;
  ' 方法区 (默认设为 public: +)
  + 添加错题();
  + 移除错题();
  + 标记掌握();
  + 加入复习计划();
  + 导出();
}
class "ReviewTask" {
  ' 属性区 (默认设为 private: -)
  - 单词ID;
  - 复习时间;
  - 单词掌握等级;
  - 上次学习时间;
  - 用户ID;
  - 复习模式;
  ' 方法区 (默认设为 public: +)
  + 生成复习任务();
  + 完成复习();
  + 调整掌握等级();
  + 快速复习();
}
class "StudyGroup" {
  ' 属性区 (默认设为 private: -)
  - 小组名称;
  - 创建者ID;
  - 成员列表;
  - 打卡目标;
  - 打卡周期;
  - 创建时间;
  - 小队排行榜;
  ' 方法区 (默认设为 public: +)
  + 创建小组();
  + 加入小组();
  + 打卡();
  + 提醒未打卡成员();
}
class "Test" {
  ' 属性区 (默认设为 private: -)
  - 测试类型;
  - 测试范围;
  - 测试题目列表;
  - 测试时间;
  - 用户ID;
  - 测试题型;
  ' 方法区 (默认设为 public: +)
  + 开始测试();
  + 提交测试();
  + 评分();
  + 生成报告();
}
class "TestResult" {
  ' 属性区 (默认设为 private: -)
  - 正确率;
  - 错误单词清单;
  - 薄弱点分析;
  - 测试时间;
  - 用户ID;
  - 测试ID;
  - 得分;
  ' 方法区 (默认设为 public: +)
  + 保存();
  + 分享();
}
class "User" {
  ' 属性区 (默认设为 private: -)
  - 用户ID;
  - 手机号;
  - 昵称;
  - 头像;
  - 学习目标;
  - 个性签名;
  - 累计学习天数;
  - 背词总量;
  - 连续打卡天数;
  - 会员状态;
  ' 方法区 (默认设为 public: +)
  + 注册();
  + 登录();
  + 修改个人信息();
  + 查看学习档案();
}
class "UserWordCollection" {
  ' 属性区 (默认设为 private: -)
  - 单词ID;
  - 用户ID;
  - 收藏类型;
  - 添加时间;
  - 所属词书;
  - 个人笔记;
  ' 方法区 (默认设为 public: +)
  + 添加单词();
  + 移除单词();
  + 批量加入复习计划();
  + 筛选();
}
class "UserWordRecord" {
  ' 属性区 (默认设为 private: -)
  - 单词ID;
  - 用户ID;
  - 掌握等级;
  - 上次学习时间;
  - 下次复习时间;
  - 学习次数;
  - 复习次数;
  - 错误次数;
  ' 方法区 (默认设为 public: +)
  + 更新掌握等级();
  + 记录学习();
  + 记录复习();
  + 获取下一次复习时间();
}
class "VocabularyBook" {
  ' 属性区 (默认设为 private: -)
  - 词书ID;
  - 词书名称;
  - 分类;
  - 词汇总量;
  - 适用人群;
  - 词书简介;
  - 大纲;
  - 用户评分;
  - 学习人数;
  - 免费/会员专属;
  ' 方法区 (默认设为 public: +)
  + 订阅();
  + 取消订阅();
  + 预览();
  + 搜索();
  + 排序();
}
class "Word" {
  ' 属性区 (默认设为 private: -)
  - 单词拼写;
  - 音标;
  - 核心释义;
  - 词性变化;
  - 例句;
  - 常用搭配;
  - 词根词缀;
  - 同义词;
  - 反义词;
  - 考点;
  - 考频;
  ' 方法区 (默认设为 public: +)
  + 获取发音();
  + 显示释义();
  + 加入生词本();
  + 标记熟词();
}

' 2.1 Association (关联关系: --)
"User" -- "CheckIn"
"User" -- "CommunityPost"
"User" -- "LearningPlan"
"User" -- "MistakeBook"
"User" -- "StudyGroup"
"User" -- "Test"
"User" -- "UserWordCollection"
"User" -- "Achievement"
"UserWordCollection" -- "Word"
"Test" -- "TestResult"
"Test" -- "VocabularyBook"
"LearningPlan" -- "VocabularyBook"
"ReviewTask" -- "VocabularyBook"
"CustomVocabularyBook" -- "VocabularyBook"
"UserWordRecord" -- "Word"
"CommunityPost" -- "User"
"CheckIn" -- "User"
"CustomVocabularyBook" --|> "VocabularyBook"
"LearningSession" *-- "UserWordRecord"
"MistakeBook" *-- "UserWordRecord"
"VocabularyBook" o-- "Word"
"StudyGroup" o-- "User"
@enduml