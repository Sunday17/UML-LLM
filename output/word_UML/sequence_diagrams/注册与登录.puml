@startuml
title 时序图：注册与登录
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "APP登录页面"
control "用户认证服务"
control "用户数据服务"
control "学习计划服务"
database "用户数据库"
database "学习计划数据库"
participant "第三方登录网关"
"用户" -> "APP登录页面" : 启动APP，进入登录页
"用户" -> "APP登录页面" : 选择登录方式（手机/微信/Apple ID）
"用户" -> "APP登录页面" : 输入手机号并请求验证码
"APP登录页面" -> "用户认证服务" : 发送验证码请求
"用户认证服务" -> "第三方登录网关" : 调用短信服务发送验证码
"第三方登录网关" --> "用户认证服务" : 返回验证码发送成功结果
"用户认证服务" --> "APP登录页面" : 返回验证码发送成功
"用户" -> "APP登录页面" : 输入收到的验证码并提交
"APP登录页面" -> "用户认证服务" : 提交验证码进行验证
"用户认证服务" -> "用户数据库" : 查询用户是否首次登录
"用户数据库" --> "用户认证服务" : 返回用户查询结果（新用户/老用户）
"用户认证服务" --> "APP登录页面" : 返回登录成功及用户状态（新用户/老用户）
"用户数据服务" -> "用户数据库" : 为新用户创建初始用户档案记录
"用户数据库" --> "用户数据服务" : 返回用户档案创建成功
"APP登录页面" -> "学习计划服务" : 为新用户请求生成初始学习计划（含学习目标、考试时间、每日背词量）
"学习计划服务" -> "学习计划数据库" : 保存生成的初始学习计划
"学习计划数据库" --> "学习计划服务" : 返回学习计划保存成功
"学习计划服务" --> "APP登录页面" : 返回初始学习计划生成成功
"APP登录页面" --> "用户" : 引导新用户进入新手引导流程
"APP登录页面" --> "用户" : 引导老用户直接进入首页学习Tab
"用户" -> "APP登录页面" : 点击“游客模式”入口
"APP登录页面" -> "用户认证服务" : 请求创建临时游客身份
"用户认证服务" -> "用户数据库" : 创建临时游客数据记录
"用户数据库" --> "用户认证服务" : 返回游客身份创建成功
"用户认证服务" --> "APP登录页面" : 返回游客模式进入成功
"APP登录页面" --> "用户" : 进入游客模式下的受限首页
"用户" -> "APP登录页面" : 点击微信授权登录按钮
"APP登录页面" -> "第三方登录网关" : 请求微信授权
"第三方登录网关" --> "APP登录页面" : 返回授权成功令牌
"APP登录页面" -> "用户认证服务" : 提交第三方授权令牌进行验证与绑定
"用户认证服务" -> "用户数据库" : 基于第三方身份信息查询或创建用户
@enduml