@startuml
title 时序图：使用拍照查词
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "APP拍照查词界面"
control "拍照查词服务"
participant "图像识别引擎"
database "单词数据库"
control "生词本管理服务"
database "用户学习数据数据库"
database "离线词库缓存"
"用户" -> "APP拍照查词界面" : 触发拍照或选择图片导入
"APP拍照查词界面" -> "拍照查词服务" : 发送图像数据并请求单词识别
"拍照查词服务" -> "图像识别引擎" : 调用图像识别API处理图像
"图像识别引擎" --> "拍照查词服务" : 返回识别出的单词文本列表
"拍照查词服务" -> "离线词库缓存" : 查询单词释义及详情
"离线词库缓存" --> "拍照查词服务" : 返回单词详情数据
"拍照查词服务" -> "用户学习数据数据库" : 保存查词历史记录
"用户学习数据数据库" --> "拍照查词服务" : 返回保存成功确认
"拍照查词服务" --> "APP拍照查词界面" : 返回单词详情及识别结果
"APP拍照查词界面" --> "用户" : 渲染并展示单词详情界面
"用户" -> "APP拍照查词界面" : 请求将单词加入生词本
"APP拍照查词界面" -> "生词本管理服务" : 发送添加单词到生词本请求
"生词本管理服务" -> "用户学习数据数据库" : 更新用户生词本记录
"用户学习数据数据库" --> "生词本管理服务" : 返回更新成功确认
"生词本管理服务" --> "APP拍照查词界面" : 返回生词本添加成功状态
"APP拍照查词界面" --> "用户" : 展示已加入生词本提示消息
@enduml