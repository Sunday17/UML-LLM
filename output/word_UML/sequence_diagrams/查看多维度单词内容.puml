@startuml
title 时序图：查看多维度单词内容
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "单词学习APP前端"
control "单词内容服务"
database "词书数据库"
database "单词数据库"
database "用户学习档案数据库"
database "离线资源缓存"
participant "第三方语音合成服务"
"用户" -> "单词学习APP前端" : 点击查看当前单词多维度详情按钮
"单词学习APP前端" -> "单词内容服务" : 发送获取单词多维度内容请求（包含单词ID、用户ID和词书ID）
"单词内容服务" -> "离线资源缓存" : 查询单词离线内容
"离线资源缓存" --> "单词内容服务" : 返回缓存数据
"单词内容服务" -> "单词数据库" : 查询单词基础信息（音标、核心释义、例句等）
"单词数据库" --> "单词内容服务" : 返回单词基础信息
"单词内容服务" -> "词书数据库" : 查询单词在指定词书中的额外内容（如考点、真题例句）
"词书数据库" --> "单词内容服务" : 返回词书特定内容
"单词内容服务" -> "用户学习档案数据库" : 查询用户对该单词的个人笔记和掌握等级
"用户学习档案数据库" --> "单词内容服务" : 返回用户个人数据
"单词内容服务" --> "单词学习APP前端" : 返回整合后的单词多维度内容数据
"单词学习APP前端" --> "用户" : 展示单词多维度内容界面（包括音标、发音、释义、例句等）
@enduml