@startuml
title 时序图：切换背词模式
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "单词学习APP前端"
control "背词模式切换控制器"
control "学习会话服务"
database "用户单词记录数据库"
database "单词内容数据库"
"用户" -> "单词学习APP前端" : 点击切换背词模式按钮并选择目标模式（如听音辨词）
"单词学习APP前端" -> "背词模式切换控制器" : 发送切换背词模式请求，包含目标模式和当前会话标识
"背词模式切换控制器" -> "学习会话服务" : 请求更新当前学习会话的背词模式
"学习会话服务" -> "用户单词记录数据库" : 查询当前学习会话的单词记录和用户设置
"用户单词记录数据库" --> "学习会话服务" : 返回用户当前学习会话的单词记录和设置数据
"学习会话服务" -> "单词内容数据库" : 根据新背词模式查询单词内容（如音频、拼写提示等）
"单词内容数据库" --> "学习会话服务" : 返回单词内容数据（如音频URL、拼写信息）
"学习会话服务" --> "背词模式切换控制器" : 返回模式切换成功及更新后的会话数据
"背词模式切换控制器" --> "单词学习APP前端" : 返回背词模式切换成功响应及新模式的界面配置
"单词学习APP前端" --> "用户" : 展示切换后的背词模式界面，加载新内容（如音频播放器）
@enduml