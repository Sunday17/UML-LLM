@startuml
title 时序图：浏览官方词书库
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "词书前端页面"
control "词书管理服务"
database "词书数据库"
database "用户数据库"
database "缓存系统"
"用户" -> "词书前端页面" : 点击进入‘词书’Tab
"词书前端页面" -> "缓存系统" : 查询词书首页缓存数据
"缓存系统" --> "词书前端页面" : 返回缓存的词书分类及推荐列表
"词书前端页面" -> "用户数据库" : 查询用户已订阅词书信息
"用户数据库" --> "词书前端页面" : 返回用户的订阅状态列表
"词书前端页面" -> "词书管理服务" : 发送词书首页数据请求（含用户偏好）
"词书管理服务" -> "词书数据库" : 查询全部分类信息及推荐词书列表
"词书数据库" --> "词书管理服务" : 返回分类列表及推荐词书概要数据
"词书管理服务" --> "词书前端页面" : 返回首页词书分类及推荐列表
"词书前端页面" -> "缓存系统" : 更新词书首页缓存数据
"词书前端页面" --> "用户" : 渲染展示词书分类导航及推荐列表
"用户" -> "词书前端页面" : 点击某个分类标签（如‘四六级’）
"词书前端页面" -> "词书管理服务" : 发送分类查询请求（分类ID，排序方式）
"词书管理服务" -> "词书数据库" : 按分类及排序规则查询词书列表
"词书数据库" --> "词书管理服务" : 返回符合条件的词书列表概要
"词书管理服务" --> "词书前端页面" : 返回分类词书列表数据
"词书前端页面" --> "用户" : 渲染展示该分类下的词书列表
"用户" -> "词书前端页面" : 在搜索框输入关键词并触发搜索
"词书前端页面" -> "词书管理服务" : 发送词书搜索请求（关键词）
"词书管理服务" -> "词书数据库" : 执行关键词模糊匹配查询词书信息
"词书数据库" --> "词书管理服务" : 返回搜索结果词书列表
"词书管理服务" --> "词书前端页面" : 返回词书搜索结果
"词书前端页面" --> "用户" : 渲染展示搜索结果的词书列表
"用户" -> "词书前端页面" : 点击某本词书条目查看详情
"词书前端页面" -> "词书管理服务" : 发送词书详情查询请求（词书ID）
"词书管理服务" -> "词书数据库" : 查询词书的详细信息及前20个单词预览内容
"词书数据库" --> "词书管理服务" : 返回词书完整详情及预览单词
"词书管理服务" --> "词书前端页面" : 返回词书详情数据
"词书前端页面" --> "用户" : 渲染展示词书详情页（含预览功能）
"用户" -> "词书前端页面" : 离开词书详情页，返回列表页
"词书前端页面" -> "用户数据库" : 记录用户浏览词书行为（可选）
@enduml