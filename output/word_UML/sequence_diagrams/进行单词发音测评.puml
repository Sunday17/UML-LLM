@startuml
title 时序图：进行单词发音测评
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "单词学习APP前端"
control "发音测评服务"
participant "语音识别引擎"
database "单词数据库"
database "用户学习记录数据库"
"用户" -> "单词学习APP前端" : 在单词学习/复习页面点击发音测评按钮
"单词学习APP前端" -> "发音测评服务" : 请求获取当前单词/例句的测评内容与标准发音
"发音测评服务" -> "单词数据库" : 查询当前单词的详细内容与标准发音文件路径
"单词数据库" --> "发音测评服务" : 返回单词的音标、标准发音、例句文本
"发音测评服务" --> "单词学习APP前端" : 返回测评界面数据，包括单词/例句文本及标准发音
"单词学习APP前端" --> "用户" : 展示测评界面，播放标准发音，提示用户跟读
"用户" -> "单词学习APP前端" : 点击录音按钮并跟读单词/例句
"单词学习APP前端" -> "发音测评服务" : 发送用户录音音频数据
"发音测评服务" -> "语音识别引擎" : 提交音频数据进行发音评分分析
"语音识别引擎" --> "发音测评服务" : 返回发音评分结果与纠错建议（音标、重音、流利度）
"发音测评服务" -> "用户学习记录数据库" : 存储本次发音测评记录（单词、评分、时间）
"用户学习记录数据库" --> "发音测评服务" : 返回存储成功确认
"发音测评服务" --> "单词学习APP前端" : 返回测评结果（评分、纠错建议）
"单词学习APP前端" --> "用户" : 展示评分结果与纠错建议，并提供回放对比功能
@enduml