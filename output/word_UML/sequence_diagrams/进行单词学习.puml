@startuml
title 时序图：进行单词学习
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "单词学习APP前端"
control "学习计划服务"
control "单词学习服务"
control "记忆算法服务"
control "用户学习数据服务"
control "词书内容服务"
database "用户数据库"
database "学习记录数据库"
database "词书数据库"
database "离线缓存"
participant "语音识别服务"
"用户" -> "单词学习APP前端" : 点击首页“开始学习”按钮
"单词学习APP前端" -> "学习计划服务" : 请求获取今日学习任务列表
"学习计划服务" -> "用户学习数据服务" : 查询用户当日学习计划
"用户学习数据服务" -> "学习记录数据库" : 检索用户今日待学习/复习的单词ID列表及计划详情
"学习记录数据库" --> "用户学习数据服务" : 返回今日任务列表
"用户学习数据服务" --> "学习计划服务" : 返回包含单词ID及学习状态的任务列表
"学习计划服务" --> "单词学习APP前端" : 返回今日学习任务详情（如：新学10个，复习30个）
"单词学习APP前端" --> "用户" : 展示第一个待学习单词及发音，并提供掌握度选择按钮（认识/模糊/不认识）
"用户" -> "单词学习APP前端" : 对当前单词做出掌握度判断（如：点击“认识”）
"单词学习APP前端" -> "单词学习服务" : 上报用户对单词[ID:xxx]的掌握度反馈
"单词学习服务" -> "记忆算法服务" : 请求根据当前掌握度计算该单词新的记忆等级及下次复习时间
"记忆算法服务" --> "单词学习服务" : 返回更新后的记忆等级（如：从1级升至2级）及下次复习时间戳
"单词学习服务" -> "用户学习数据服务" : 更新该单词在用户学习记录中的记忆等级、最后学习时间及下次复习时间
"用户学习数据服务" -> "学习记录数据库" : 持久化更新单词学习记录
"学习记录数据库" --> "用户学习数据服务" : 返回数据更新成功确认
"用户学习数据服务" --> "单词学习服务" : 返回学习记录更新成功
"单词学习服务" --> "单词学习APP前端" : 返回当前单词学习完成确认
"单词学习APP前端" --> "用户" : 展示单词全维度内容（音标、释义、例句等），并提示可展开更多内容或加入生词本
"用户" -> "单词学习APP前端" : 点击“下一个”按钮或滑动界面
"单词学习APP前端" -> "词书内容服务" : 请求获取下一个待学习单词的详细内容
"词书内容服务" -> "词书数据库" : 查询指定单词ID的完整信息（释义、例句、发音等）
"词书数据库" --> "词书内容服务" : 返回单词详细数据
"词书内容服务" --> "单词学习APP前端" : 返回下一个单词的展示内容
"单词学习APP前端" -> "离线缓存" : 缓存单词详情数据以备离线使用
"单词学习APP前端" --> "用户" : 展示下一个单词及发音，重复学习流程
"用户学习数据服务" --> "单词学习APP前端" : 推送任务进度更新（如：已完成5/40）
"用户" -> "单词学习APP前端" : 完成当日最后一个单词的学习判断
"单词学习APP前端" -> "学习计划服务" : 通知当日学习任务全部完成
"学习计划服务" -> "用户学习数据服务" : 更新用户学习状态为“今日已完成”，并更新连续打卡天数等数据
"用户学习数据服务" -> "用户数据库" : 更新用户档案数据（累计学习天数、背词总量等）
"用户学习数据服务" -> "离线缓存" : 标记本地学习数据待同步
"离线缓存" --> "用户学习数据服务" : 在网络恢复后自动同步学习记录至云端数据库
"用户学习数据服务" --> "学习计划服务" : 返回状态更新完成确认
"学习计划服务" --> "单词学习APP前端" : 返回任务完成确认
"单词学习APP前端" --> "用户" : 弹出学习完成弹窗，展示本次学习数据与打卡入口
@enduml