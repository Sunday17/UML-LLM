@startuml
title 时序图：创建自定义词书
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "用户" << (A,#FFAAAA) >> order 0
boundary "单词学习APP前端"
control "词书管理服务"
control "用户服务"
database "自定义词书数据库"
database "用户数据库"
participant "OCR识别服务"
"用户" -> "单词学习APP前端" : 发起创建自定义词书请求
"单词学习APP前端" -> "用户服务" : 发送用户权限查询请求
"用户服务" -> "用户数据库" : 查询用户已创建词书数量和会员状态
"用户数据库" --> "用户服务" : 返回用户词书数量及会员状态
"用户服务" --> "单词学习APP前端" : 返回允许创建自定义词书结果
"单词学习APP前端" --> "用户" : 展示自定义词书创建方式选择界面
"用户" -> "单词学习APP前端" : 选择拍照识别导入方式
"单词学习APP前端" -> "OCR识别服务" : 发送图片识别请求
"OCR识别服务" --> "单词学习APP前端" : 返回单词识别结果
"单词学习APP前端" --> "用户" : 展示识别单词列表供确认编辑
"用户" -> "单词学习APP前端" : 提交自定义词书创建表单
"单词学习APP前端" -> "词书管理服务" : 发起自定义词书创建请求
"词书管理服务" -> "用户服务" : 请求验证用户自定义词书创建权限
"用户服务" -> "用户数据库" : 查询用户已创建词书数量
"用户数据库" --> "用户服务" : 返回用户词书数量
"用户服务" --> "词书管理服务" : 返回用户创建权限验证结果
"词书管理服务" -> "自定义词书数据库" : 插入新自定义词书记录
"自定义词书数据库" --> "词书管理服务" : 返回自定义词书创建成功结果
"词书管理服务" --> "单词学习APP前端" : 返回自定义词书创建成功响应
"单词学习APP前端" --> "用户" : 展示自定义词书创建成功通知
@enduml