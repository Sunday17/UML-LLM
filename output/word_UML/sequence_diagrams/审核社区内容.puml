@startuml
title 时序图：审核社区内容
skinparam maxMessageSize 150
skinparam sequenceMessageAlign center
autonumber "<b>[00]"

skinparam sequence {
    ArrowColor #336699
    ActorBorderColor #336699
    LifeLineBorderColor #336699
    LifeLineBackgroundColor #E2E8F0
    
    ParticipantBorderColor #336699
    ParticipantBackgroundColor #EBF4FA
    ParticipantFontColor #333333
    ParticipantFontSize 14
    
    DatabaseBorderColor #336699
    DatabaseBackgroundColor #EBF4FA
    DatabaseFontColor #333333
    
    BoundaryBorderColor #336699
    BoundaryBackgroundColor #EBF4FA
    
    ControlBorderColor #336699
    ControlBackgroundColor #EBF4FA
}
        ' 第一个参与者使用特殊标记
actor "内容审核人员" << (A,#FFAAAA) >> order 0
boundary "社区内容审核页面"
control "内容审核服务"
database "社区内容数据库"
database "用户数据库"
participant "第三方内容审核系统"
"内容审核服务" -> "社区内容数据库" : 查询待审核的社区内容列表
"社区内容数据库" --> "内容审核服务" : 返回待审核内容列表（包含内容ID、发布者、内容文本、图片等）
"内容审核服务" -> "第三方内容审核系统" : 调用接口，提交文本与图片进行机审
"第三方内容审核系统" --> "内容审核服务" : 返回机审结果（通过/疑似违规/违规）及标签
"内容审核服务" -> "社区内容审核页面" : 推送待审核内容详情及机审结果
"社区内容审核页面" --> "内容审核人员" : 展示待审核内容详情、发布者信息及机审结果
"内容审核人员" -> "社区内容审核页面" : 查看内容，并选择审核操作（通过/标记违规/移入回收站）
"社区内容审核页面" -> "内容审核服务" : 提交人工审核结果与操作指令
"内容审核服务" -> "社区内容数据库" : 更新对应内容的审核状态与可见性
"社区内容数据库" --> "内容审核服务" : 返回更新操作结果
"内容审核服务" -> "用户数据库" : 若内容违规，更新发布者的违规记录
"用户数据库" --> "内容审核服务" : 返回用户违规记录更新结果
"内容审核服务" --> "社区内容审核页面" : 返回本次内容审核处理完成的结果
@enduml