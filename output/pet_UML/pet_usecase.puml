@startuml
title 自动生成：系统用例图
left to right direction

skinparam packageStyle rectangle
skinparam nodesep 15
skinparam ranksep 40
skinparam usecase {
    BackgroundColor #F9F9F9
    BorderColor #333333
    ArrowColor #666666
}
skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
}


actor "用户"

rectangle "系统核心功能" {

    usecase "取消报名"

    usecase "查看活动详情"

    usecase "查看我的活动"

    usecase "浏览活动"

    usecase "报名活动"

}

    
"用户" -- "浏览活动"
    
"用户" -- "查看活动详情"
    
"用户" -- "报名活动"
    
"用户" -- "取消报名"
    
"用户" -- "查看我的活动"
    



    
"查看活动详情" ..> "浏览活动" : <<include>>
    

    
"查看我的活动" ..> "浏览活动" : <<include>>
    



    
"报名活动" <.. "取消报名" : <<extend>>
    





@enduml