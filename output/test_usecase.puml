@startuml
title 自动生成：系统用例图
left to right direction

' --- 1. 优化排版与样式参数 ---
skinparam packageStyle rectangle
skinparam nodesep 15
skinparam ranksep 40
skinparam usecase {
    BackgroundColor #F9F9F9
    BorderColor #333333
    ArrowColor #666666
}
skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
}

' --- 2. 定义参与者 ---

actor "师生"

actor "图书管理员"


' --- 3. 定义系统边界与用例 ---
' 【优化点】使用 rectangle 包裹用例，强制参与者在左外侧，用例在右内侧，排版瞬间整洁
rectangle "系统核心功能" {

    usecase "图书信息修改"

    usecase "图书归还"

    usecase "用户注册登录"

    usecase "逾期处理"

    usecase "图书续借"

    usecase "借阅查询"

    usecase "图书检索"

    usecase "数据统计"

    usecase "图书信息录入"

    usecase "图书借阅"

}

' --- 4. 参与者与用例的关联 ---

    
"师生" -- "图书检索"
    
"师生" -- "用户注册登录"
    
"师生" -- "图书借阅"
    
"师生" -- "图书续借"
    
"师生" -- "图书归还"
    
"师生" -- "借阅查询"
    

    
"图书管理员" -- "图书信息录入"
    
"图书管理员" -- "图书信息修改"
    
"图书管理员" -- "逾期处理"
    
"图书管理员" -- "数据统计"
    


' --- 5. 包含关系 (Include) ---
' 规范：基础用例 -> 包含用例

    
"图书借阅" ..> "图书检索" : <<include>>
    
"图书借阅" ..> "用户注册登录" : <<include>>
    

    
"图书续借" ..> "图书借阅" : <<include>>
    

    
"图书归还" ..> "图书借阅" : <<include>>
    

    
"借阅查询" ..> "用户注册登录" : <<include>>
    

    
"逾期处理" ..> "图书借阅" : <<include>>
    

    
"数据统计" ..> "图书借阅" : <<include>>
    


' --- 6. 扩展关系 (Extend) ---
' 规范：扩展用例 -> 基础用例
' 【核心修复】使用 <.. 语法。这会让 PlantUML 把 Base 画在左边，Ext 画在右边，但箭头反向指向 Base。完美解决布局混乱！

    
"图书借阅" <.. "图书续借" : <<extend>>
    
"图书借阅" <.. "图书归还" : <<extend>>
    
"图书借阅" <.. "逾期处理" : <<extend>>
    


' --- 7. 用例泛化 ---
' 【排版修复】使用 <|-- 让父类在左，子类在右，箭头指向父类


' --- 8. 参与者泛化 ---

@enduml