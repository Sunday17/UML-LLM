@startuml
title 自动生成：系统类图
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50

' ==========================================
' 1. 定义类及其属性与方法
' ==========================================

class "User" {
  ' 属性区 (默认设为 private: -)
  - student_id;
  - name;
  - password;
  - account_status;
  
  ' 方法区 (默认设为 public: +)
  + register();
  + login();
  + recoverPassword();
}

class "Book" {
  ' 属性区 (默认设为 private: -)
  - title;
  - author;
  - isbn;
  - category;
  - inventory_count;
  - location;
  - borrow_status;
  
  ' 方法区 (默认设为 public: +)
  + getDetails();
  + updateStatus();
}

class "BorrowRecord" {
  ' 属性区 (默认设为 private: -)
  - record_id;
  - user_id;
  - book_id;
  - borrow_date;
  - due_date;
  - return_date;
  - overdue_fee;
  
  ' 方法区 (默认设为 public: +)
  + calculateOverdueFee();
  + updateReturnStatus();
}

class "BorrowOrder" {
  ' 属性区 (默认设为 private: -)
  - order_id;
  - user_id;
  - book_id;
  - borrow_date;
  - order_status;
  
  ' 方法区 (默认设为 public: +)
  + generateOrder();
  + validateBorrowRights();
}

class "BookCategory" {
  ' 属性区 (默认设为 private: -)
  - category_id;
  - category_name;
  - description;
  
  ' 方法区 (默认设为 public: +)
  + getBooksInCategory();
  + addCategory();
}

class "LibraryLocation" {
  ' 属性区 (默认设为 private: -)
  - location_id;
  - location_name;
  - description;
  
  ' 方法区 (默认设为 public: +)
  + getLocationDetails();
  + updateLocation();
}

class "OverdueFee" {
  ' 属性区 (默认设为 private: -)
  - fee_id;
  - borrow_record_id;
  - amount;
  - status;
  
  ' 方法区 (默认设为 public: +)
  + calculateFee();
  + markAsPaid();
}

class "OperationLog" {
  ' 属性区 (默认设为 private: -)
  - log_id;
  - operation_type;
  - timestamp;
  - user_id;
  - details;
  
  ' 方法区 (默认设为 public: +)
  + logOperation();
  + getLogs();
}

class "StatisticsReport" {
  ' 属性区 (默认设为 private: -)
  - report_id;
  - period;
  - data;
  - generation_date;
  
  ' 方法区 (默认设为 public: +)
  + generateReport();
  + exportReport();
}

class "BookInventory" {
  ' 属性区 (默认设为 private: -)
  - inventory_id;
  - book_id;
  - total_count;
  - available_count;
  - location;
  
  ' 方法区 (默认设为 public: +)
  + updateInventory();
  + checkAvailability();
}



' ==========================================
' 2. 定义类之间的关系
' ==========================================

' 2.1 Association (关联关系: --)

"User" -- "BorrowRecord"

"User" -- "BorrowOrder"

"Book" -- "BorrowRecord"

"Book" -- "BookCategory"

"Book" -- "LibraryLocation"

"Book" -- "BookInventory"

"BorrowRecord" -- "OverdueFee"

"BorrowOrder" -- "BorrowRecord"

"StatisticsReport" -- "BorrowRecord"

"StatisticsReport" -- "Book"


' 2.2 Generalization (泛化/继承关系: --|>)
' 注意：PlantUML 中箭头指向父类，所以如果是 ["子类", "父类"]，用 --|>


' 2.3 Composition (组合关系: *--)
' 注意：强整体拥有部分，如果是 ["整体", "部分"]，用 *--

"BorrowOrder" *-- "BorrowRecord"


' 2.4 Aggregation (聚合关系: o--)
' 注意：弱整体包含部分，如果是 ["整体", "部分"]，用 o--

"Book" o-- "BookInventory"


' 2.5 Dependency (依赖关系: ..>)
' 注意：源类依赖目标类，如果是 ["源类", "目标类"]，用 ..>

"OperationLog" ..> "User"

"OperationLog" ..> "Book"

"StatisticsReport" ..> "BookInventory"


@enduml